# Copy to docker/.env and adjust before running `docker compose up`.

# Postgres credentials — change for any non-dev deployment.
POSTGRES_USER=agorio
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=agorio

# Public URL the cloud app advertises (used by Neon Auth redirects).
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Neon Auth — required for SSO. Leave blank to run in anonymous-trace-only
# mode (no API key issuance UI, /traces still works against ingested data).
NEON_AUTH_PROJECT_ID=
NEON_AUTH_API_KEY=
NEON_AUTH_JWKS_URL=

# Optional: Redis URL for @agorio/session-redis. Not required.
REDIS_URL=
