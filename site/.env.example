# ─── LOCAL DEV ─────────────────────────────────────────────────────────────────
# Copy to .env.local and fill in real values. Never commit .env.local.

# Stripe — test keys for local dev (live keys live in Vercel project envs)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL=price_...
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_...

# Site URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Neon Postgres — pooled connection for runtime
DATABASE_URL='postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require'
# Direct connection used only by drizzle-kit migrations
DATABASE_URL_UNPOOLED='postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require'

# Neon Auth — same project as cloud/
NEXT_PUBLIC_NEON_AUTH_URL=https://HOST.neonauth.REGION.aws.neon.tech/DB/auth
NEON_AUTH_BASE_URL=https://HOST.neonauth.REGION.aws.neon.tech/DB/auth
NEON_AUTH_COOKIE_SECRET=...

# Resend — transactional email
RESEND_API_KEY=re_...

# PostHog — EU cloud, project: agorio (shared with cloud/)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_UI_HOST=https://eu.posthog.com

# Google Analytics 4 — site web stream (agorio.dev). Omit locally;
# set in the agorio-site Vercel project (Production + Preview).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
